{
  "permissions": {
    "allow": [
      "Bash(yarn*)", "Bash(docker*)",
      "Bash(git *)", "Bash(npx hardhat*)",
      "Read(*)", "Write(*)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git push --force*)",
      "Bash(DROP TABLE*)"
    ]
  },
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["@modelcontextprotocol/server-github"]
    },
    "filesystem": {
      "command": "npx",
      "args": ["@modelcontextprotocol/server-filesystem", "."]
    }
  }
}