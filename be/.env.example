# ============================================
# be/.env.example — Backend Environment Variables Template
# COPY this to .env and fill in real values
# NEVER commit .env to git!
# ============================================

# ── APP ──────────────────────────────────────
NODE_ENV=development
PORT=3001
WORKER_PORT=3002
NETWORK=testnet                        # testnet | mainnet

# ── INFRA CREDENTIALS ─────────────────────────
# Used by both docker-compose AND NestJS — must match in both places
POSTGRES_USER=root
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DB=tap
REDIS_PASSWORD=your-redis-password

# ── DATABASE (PostgreSQL) ────────────────────
# Constructed from infra vars above
POSTGRES_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5434/${POSTGRES_DB}

# ── REDIS ───────────────────────────────────
REDIS_URL=redis://default:${REDIS_PASSWORD}@localhost:6380/0

# ── KAFKA ───────────────────────────────────
KAFKA_BROKER=localhost:29093
KAFKA_TOPIC_PREFIX=local-tap
KAFKA_RUNNING_FLAG=true

# ── MINIO (S3-compatible storage) ───────────
MINIO_HOST=localhost
MINIO_PORT=9002
MINIO_ACCESS_KEY=development
MINIO_SECRET_KEY=123456789
BUCKET_NAME=development

# ── EVM / CONTRACTS (BASE Sepolia) ──────────
RPC=https://sepolia.base.org
ADMIN_PRIVATE_KEY=0x...              # Your deployer/admin wallet private key
CONTRACT_TAP_ORDER=0x...             # Deployed TapOrder address
CONTRACT_PAYOUT_POOL=0x...           # Deployed PayoutPool address
CONTRACT_PRICE_FEED_ADAPTER=0x...    # Deployed PriceFeedAdapter address

# ── PRICE FEEDS (BASE Sepolia Chainlink) ────
FEED_BTC_USD=0x...                   # BTC/USD Chainlink feed
FEED_ETH_USD=0x...                   # ETH/USD Chainlink feed

# ── AUTH (JWT) ───────────────────────────────
JWT_SECRET=your-jwt-secret-min-32-chars-here

# ── PRIVY ───────────────────────────────────
PRIVY_APP_SECRET=your-privy-secret
